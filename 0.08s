<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FIFA World Cup 2026 — Official Fan Showcase</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@300;400;500;600;700&family=Oswald:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
:root {
  --fifa-navy: #0a1628;
  --fifa-blue: #1a3a6e;
  --fifa-gold: #c9a227;
  --fifa-gold-light: #f5d675;
  --fifa-red: #c1272d;
  --fifa-white: #f5f5f0;
  --fifa-silver: #b0b8c8;
  --glow-gold: 0 0 40px rgba(201,162,39,0.4);
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { scroll-behavior: smooth; }

body {
  background: var(--fifa-navy);
  color: var(--fifa-white);
  font-family: 'Inter', sans-serif;
  overflow-x: hidden;
  padding-top: 102px;
}

/* ==================== LOGO SIZE CLASSES ==================== */
.logo-nav    { height: 36px; width: auto; }
.logo-hero   { width: 220px; height: auto; }
.logo-footer { width: 80px; height: auto; }
.logo-stamp  { width: 60px; height: auto; }
.logo-section{ height: 44px; width: auto; }
.logo-ticker { height: 24px; width: auto; }

/* ==================== SECTION BRAND ROW ==================== */
.section-brand-row {
  display: flex;
  align-items: center;
  gap: 20px;
  margin-bottom: 8px;
}
.section-brand-divider {
  width: 1px;
  height: 44px;
  background: var(--fifa-gold);
  opacity: 0.5;
  flex-shrink: 0;
}
.section-brand-text { display: flex; flex-direction: column; gap: 2px; }
.section-label {
  font-family: 'Inter', sans-serif;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 2px;
  color: var(--fifa-gold);
  text-transform: uppercase;
}
.section-title {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(28px, 5vw, 48px);
  color: var(--fifa-white);
  line-height: 1;
  letter-spacing: 1px;
}
.section-title em { font-style: normal; color: var(--fifa-gold); }

/* ==================== CANVAS ==================== */
#ball-canvas {
  position: fixed;
  top: 0; left: 0;
  width: 100%; height: 100%;
  z-index: 1;
  pointer-events: none;
  opacity: 0.16;
}

/* ==================== NAVIGATION ==================== */
nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
  height: 64px;
  padding: 0 40px;
  background: rgba(10,22,40,0.93);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
  border-bottom: 1px solid rgba(201,162,39,0.18);
  display: flex;
  align-items: center;
  justify-content: space-between;
  transition: box-shadow 0.3s, border-color 0.3s;
}
nav.scrolled { box-shadow: 0 4px 20px rgba(0,0,0,0.6); }

.nav-links {
  list-style: none;
  display: flex;
  gap: 32px;
  align-items: center;
}
.nav-links a {
  font-family: 'Inter', sans-serif;
  font-size: 12px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.6px;
  color: var(--fifa-silver);
  text-decoration: none;
  padding-bottom: 4px;
  border-bottom: 2px solid transparent;
  transition: color 0.2s, border-color 0.2s;
}
.nav-links a:hover { color: var(--fifa-gold); }
.nav-links a.active { color: var(--fifa-gold); border-bottom-color: var(--fifa-gold); }

.tickets-btn {
  background: var(--fifa-gold);
  color: var(--fifa-navy);
  padding: 8px 20px;
  border-radius: 3px;
  font-family: 'Inter', sans-serif;
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1.2px;
  text-decoration: none;
  transition: opacity 0.2s, transform 0.2s;
  white-space: nowrap;
}
.tickets-btn:hover { opacity: 0.88; }
.tickets-btn:focus-visible { outline: 2px solid #c9a227; outline-offset: 2px; }

.hamburger {
  display: none;
  background: none;
  border: none;
  color: var(--fifa-white);
  font-size: 24px;
  cursor: pointer;
  padding: 4px 8px;
}

.mobile-menu {
  display: none;
  position: fixed;
  top: 64px; left: 0; right: 0;
  z-index: 98;
  background: var(--fifa-navy);
  border-bottom: 1px solid rgba(201,162,39,0.18);
  padding: 16px 24px;
  flex-direction: column;
  gap: 16px;
}
.mobile-menu.open { display: flex; }
.mobile-menu a {
  font-family: 'Inter', sans-serif;
  font-size: 14px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.6px;
  color: var(--fifa-silver);
  text-decoration: none;
  padding: 8px 0;
  border-bottom: 1px solid rgba(255,255,255,0.06);
}
.mobile-menu a:hover { color: var(--fifa-gold); }

/* ==================== LIVE SCORES BANNER ==================== */
.scores-banner {
  position: fixed;
  top: 64px; left: 0; right: 0;
  z-index: 99;
  height: 38px;
  background: var(--fifa-red);
  border-bottom: 2px solid rgba(255,255,255,0.12);
  overflow: hidden;
  display: flex;
  align-items: center;
}

.banner-anchor {
  flex-shrink: 0;
  width: 130px;
  height: 38px;
  background: rgba(0,0,0,0.35);
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 0 12px;
  border-right: 1px solid rgba(255,255,255,0.18);
  z-index: 2;
}
.banner-live-text {
  font-family: 'Inter', sans-serif;
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  color: #ffffff;
  white-space: nowrap;
}
.pulse-dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  background: #ff4444;
  flex-shrink: 0;
}

.banner-ticker-area {
  flex: 1;
  position: relative;
  height: 38px;
  display: flex;
  align-items: center;
  justify-content: center;
}
#ticker-item {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16px;
  height: 38px;
  transition: opacity 0.4s ease;
  width: 100%;
}
.ticker-team {
  font-family: 'Inter', sans-serif;
  font-size: 13px;
  font-weight: 600;
  color: #ffffff;
  white-space: nowrap;
}
.ticker-score {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 20px;
  background: rgba(0,0,0,0.28);
  padding: 2px 12px;
  border-radius: 3px;
  color: #ffffff;
  white-space: nowrap;
}
.ticker-status {
  font-family: 'Inter', sans-serif;
  font-size: 9px;
  font-weight: 700;
  padding: 2px 6px;
  border-radius: 2px;
  white-space: nowrap;
}
.ticker-status.live {
  background: #ffffff;
  color: var(--fifa-red);
}
.ticker-status.ft {
  background: rgba(255,255,255,0.15);
  color: #ffffff;
}

.banner-dots {
  position: absolute;
  right: 16px;
  display: flex;
  gap: 4px;
  align-items: center;
}
.banner-dot {
  width: 4px; height: 4px;
  border-radius: 50%;
  background: white;
  opacity: 0.3;
  transition: opacity 0.3s;
}
.banner-dot.active { opacity: 1; }

/* ==================== HERO SECTION ==================== */
#hero {
  min-height: 100vh;
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 20px 20px 60px;
  background:
    linear-gradient(to bottom, transparent 75%, var(--fifa-navy) 100%),
    radial-gradient(ellipse 75% 55% at 50% 62%, rgba(26,58,110,0.5) 0%, transparent 100%),
    var(--fifa-navy);
  overflow: hidden;
}

.pitch-overlay {
  position: absolute;
  inset: 0;
  opacity: 0.04;
  pointer-events: none;
}

.live-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: rgba(193,39,45,0.12);
  border: 1px solid rgba(193,39,45,0.35);
  border-radius: 100px;
  padding: 6px 16px;
  font-family: 'Inter', sans-serif;
  font-size: 11px;
  font-weight: 600;
  color: #ff6b6b;
  margin-bottom: 28px;
  position: relative;
  z-index: 3;
}
.live-dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  background: #ff6b6b;
}

.hero-logo-wrap {
  position: relative;
  z-index: 3;
  margin-bottom: 24px;
  filter: drop-shadow(var(--glow-gold));
}

.hero-headline {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(72px, 14vw, 190px);
  line-height: 0.86;
  letter-spacing: -1px;
  background: linear-gradient(90deg, #ffffff 0%, #c9a227 55%, #ffffff 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 4px;
  position: relative;
  z-index: 3;
}
.hero-sub {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(18px, 3.5vw, 48px);
  color: var(--fifa-silver);
  letter-spacing: 5px;
  margin-bottom: 28px;
  position: relative;
  z-index: 3;
}
.hero-flags {
  font-family: 'Inter', sans-serif;
  font-size: 14px;
  font-weight: 600;
  margin-bottom: 44px;
  position: relative;
  z-index: 3;
  color: var(--fifa-white);
}

.countdown {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
  justify-content: center;
  margin-bottom: 48px;
  position: relative;
  z-index: 3;
}
.cd-block {
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(201,162,39,0.2);
  border-radius: 6px;
  padding: 16px 22px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  min-width: 80px;
}
.cd-num {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 54px;
  color: var(--fifa-gold);
  line-height: 1;
}
.cd-label {
  font-family: 'Inter', sans-serif;
  font-size: 10px;
  color: var(--fifa-silver);
  text-transform: uppercase;
  letter-spacing: 2px;
}

.hero-ctas {
  display: flex;
  gap: 14px;
  flex-wrap: wrap;
  justify-content: center;
  position: relative;
  z-index: 3;
}
.btn-primary {
  background: var(--fifa-gold);
  color: var(--fifa-navy);
  padding: 13px 34px;
  border-radius: 3px;
  font-family: 'Inter', sans-serif;
  font-size: 12px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1px;
  text-decoration: none;
  border: none;
  cursor: pointer;
  transition: transform 0.2s, box-shadow 0.2s;
  display: inline-block;
}
.btn-primary:hover { transform: translateY(-2px); box-shadow: var(--glow-gold); }
.btn-secondary {
  background: transparent;
  color: var(--fifa-white);
  padding: 13px 34px;
  border-radius: 3px;
  font-family: 'Inter', sans-serif;
  font-size: 12px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1px;
  text-decoration: none;
  border: 1px solid rgba(255,255,255,0.3);
  cursor: pointer;
  transition: border-color 0.2s, color 0.2s;
  display: inline-block;
}
.btn-secondary:hover { border-color: var(--fifa-gold); color: var(--fifa-gold); }

.scroll-indicator {
  position: absolute;
  bottom: 28px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
  font-family: 'Inter', sans-serif;
  font-size: 10px;
  color: var(--fifa-silver);
  letter-spacing: 2px;
  z-index: 3;
}
.scroll-line {
  width: 1px;
  height: 24px;
  background: var(--fifa-silver);
  opacity: 0.4;
}

/* ==================== STATS STRIP ==================== */
.stats-strip {
  background: var(--fifa-blue);
  border-top: 3px solid var(--fifa-gold);
  border-bottom: 3px solid var(--fifa-gold);
  padding: 0;
  position: relative;
  z-index: 2;
}
.stats-logo-row {
  display: flex;
  justify-content: center;
  padding: 24px 0 0;
}
.stats-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
}
.stat-item {
  padding: 30px 16px;
  text-align: center;
  border-right: 1px solid rgba(255,255,255,0.07);
}
.stat-item:last-child { border-right: none; }
.stat-num {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 56px;
  color: var(--fifa-gold);
  display: block;
  line-height: 1;
}
.stat-label {
  font-family: 'Inter', sans-serif;
  font-size: 11px;
  color: var(--fifa-silver);
  text-transform: uppercase;
  letter-spacing: 1.5px;
  display: block;
  margin-top: 4px;
}

/* ==================== GENERIC SECTION ==================== */
.section {
  padding: 80px 40px;
  position: relative;
  z-index: 2;
}
.section-subtitle {
  font-family: 'Inter', sans-serif;
  font-size: 15px;
  color: var(--fifa-silver);
  margin-top: 8px;
  margin-bottom: 40px;
}

/* ==================== VENUES ==================== */
#venues { background: var(--fifa-navy); }
.venues-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 16px;
  margin-top: 40px;
}
.venue-card {
  border: 0.5px solid rgba(255,255,255,0.08);
  border-radius: 8px;
  overflow: hidden;
  transition: transform 0.25s, border-color 0.25s;
  background: rgba(10,22,40,0.6);
}
.venue-card:hover { transform: translateY(-5px); border-color: rgba(201,162,39,0.5); }
.venue-img {
  height: 155px;
  background: linear-gradient(to bottom, var(--fifa-blue) 0%, #0d2140 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56px;
  position: relative;
  overflow: hidden;
}
.venue-img::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(to bottom, rgba(10,22,40,0) 40%, rgba(10,22,40,0.8) 100%);
}
.venue-info { padding: 18px 20px; }
.venue-city {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 22px;
  color: var(--fifa-white);
  display: block;
}
.venue-name {
  font-family: 'Inter', sans-serif;
  font-size: 13px;
  color: var(--fifa-silver);
  margin-bottom: 10px;
  display: block;
}
.venue-cap {
  font-family: 'Inter', sans-serif;
  font-size: 12px;
  font-weight: 600;
  color: var(--fifa-gold);
}

/* ==================== GROUPS ==================== */
#groups {
  background: linear-gradient(180deg, var(--fifa-navy) 0%, var(--fifa-blue) 50%, var(--fifa-navy) 100%);
}
.groups-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(210px, 1fr));
  gap: 14px;
  margin-top: 40px;
}
.group-card {
  background: rgba(10,22,40,0.65);
  border: 1px solid rgba(201,162,39,0.18);
  border-radius: 8px;
  padding: 20px;
  transition: border-color 0.25s;
}
.group-card:hover { border-color: rgba(201,162,39,0.45); }
.group-card.hidden-group { display: none; }
.group-header {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 14px;
}
.group-letter {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 34px;
  color: var(--fifa-gold);
  line-height: 1;
}
.group-badge {
  font-family: 'Inter', sans-serif;
  font-size: 10px;
  color: var(--fifa-silver);
  background: rgba(255,255,255,0.07);
  padding: 3px 8px;
  border-radius: 2px;
  letter-spacing: 1px;
}
.team-row {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 7px 0;
  border-bottom: 1px solid rgba(255,255,255,0.06);
}
.team-row:last-child { border-bottom: none; }
.team-flag { font-size: 20px; line-height: 1; }
.team-name {
  font-family: 'Inter', sans-serif;
  font-size: 13px;
  color: var(--fifa-white);
  flex: 1;
}
.team-pts {
  font-family: 'Inter', sans-serif;
  font-size: 13px;
  font-weight: 700;
  color: var(--fifa-gold);
}
.groups-expand {
  display: flex;
  justify-content: center;
  margin-top: 28px;
}
.expand-btn {
  background: none;
  border: 1px solid rgba(201,162,39,0.35);
  color: var(--fifa-gold);
  font-family: 'Inter', sans-serif;
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 1px;
  text-transform: uppercase;
  padding: 10px 28px;
  border-radius: 3px;
  cursor: pointer;
  transition: background 0.2s, color 0.2s;
}
.expand-btn:hover { background: rgba(201,162,39,0.1); }

/* ==================== PLAYERS ==================== */
#players { background: var(--fifa-navy); }
.players-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(185px, 1fr));
  gap: 20px;
  margin-top: 40px;
}
.player-card {
  border-radius: 12px;
  overflow: hidden;
  border: 1px solid rgba(255,255,255,0.08);
  transition: all 0.28s;
  position: relative;
  background: rgba(10,22,40,0.7);
}
.player-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: var(--fifa-gold);
  transform: scaleX(0);
  transition: transform 0.28s;
  z-index: 5;
  transform-origin: left;
}
.player-card:hover::before { transform: scaleX(1); }
.player-card:hover {
  transform: translateY(-5px);
  border-color: rgba(201,162,39,0.45);
  box-shadow: 0 16px 40px rgba(0,0,0,0.4);
}
.jersey-zone {
  position: relative;
  height: 160px;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}
.player-jersey-bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}
.player-jersey-svg {
  width: 100px;
  height: 120px;
  position: relative;
  z-index: 2;
  filter: drop-shadow(0 4px 12px rgba(0,0,0,0.5));
  transition: transform 0.28s;
}
.player-card:hover .player-jersey-svg { transform: scale(1.06) translateY(-3px); }
.jersey-ghost-num {
  position: absolute;
  bottom: 8px; right: 12px;
  font-family: 'Bebas Neue', sans-serif;
  font-size: 38px;
  color: rgba(255,255,255,0.1);
  z-index: 1;
  line-height: 1;
}
.player-info {
  padding: 14px 16px 18px;
}
.player-name {
  font-family: 'Oswald', sans-serif;
  font-size: 16px;
  font-weight: 600;
  color: var(--fifa-white);
  margin-bottom: 3px;
}
.player-nation {
  display: flex;
  align-items: center;
  gap: 5px;
  font-family: 'Inter', sans-serif;
  font-size: 12px;
  color: var(--fifa-silver);
  margin-bottom: 10px;
}
.player-stat-row {
  display: flex;
  align-items: baseline;
  gap: 5px;
}
.stat-big {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 28px;
  color: var(--fifa-gold);
}
.stat-small {
  font-family: 'Inter', sans-serif;
  font-size: 10px;
  color: var(--fifa-silver);
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

/* ==================== TIMELINE ==================== */
#schedule {
  background: linear-gradient(180deg, var(--fifa-navy) 0%, var(--fifa-blue) 100%);
}
.timeline-container {
  max-width: 800px;
  margin: 40px auto 0;
  padding-left: 44px;
  position: relative;
}
.timeline-container::before {
  content: '';
  position: absolute;
  left: 14px; top: 0; bottom: 0;
  width: 2px;
  background: linear-gradient(to bottom, var(--fifa-gold) 0%, rgba(201,162,39,0.1) 100%);
}
.t-event {
  position: relative;
  margin-bottom: 36px;
}
.t-dot {
  position: absolute;
  left: -36px; top: 4px;
  width: 16px; height: 16px;
  border-radius: 50%;
  background: var(--fifa-gold);
  box-shadow: 0 0 0 5px rgba(201,162,39,0.18);
}
.t-date {
  font-family: 'Inter', sans-serif;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 1.5px;
  color: var(--fifa-gold);
  text-transform: uppercase;
}
.t-title {
  font-family: 'Oswald', sans-serif;
  font-size: 19px;
  font-weight: 600;
  color: var(--fifa-white);
  margin: 3px 0;
}
.t-desc {
  font-family: 'Inter', sans-serif;
  font-size: 13px;
  color: var(--fifa-silver);
}

/* ==================== PREDICTOR ==================== */
#predictor { background: var(--fifa-navy); }
.predictor-card {
  max-width: 580px;
  margin: 40px auto 0;
  background: rgba(26,58,110,0.38);
  border: 1px solid rgba(201,162,39,0.22);
  border-radius: 12px;
  padding: 40px;
  text-align: center;
}
.predictor-logo-row {
  display: flex;
  justify-content: center;
  margin-bottom: 24px;
}
.predictor-match {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 20px;
  margin-bottom: 20px;
  flex-wrap: wrap;
}
.pred-team {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
}
.pred-flag { font-size: 48px; line-height: 1; }
.pred-name {
  font-family: 'Oswald', sans-serif;
  font-size: 20px;
  color: var(--fifa-white);
}
.pred-vs {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 38px;
  color: var(--fifa-gold);
  opacity: 0.55;
}
.pred-instruction {
  font-family: 'Inter', sans-serif;
  font-size: 13px;
  color: var(--fifa-silver);
  margin-bottom: 16px;
}
.score-btns {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 8px;
  margin-bottom: 24px;
}
.score-btn {
  background: rgba(255,255,255,0.07);
  border: 1px solid rgba(255,255,255,0.15);
  color: var(--fifa-white);
  padding: 10px 18px;
  border-radius: 4px;
  font-family: 'Inter', sans-serif;
  font-size: 15px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.15s;
}
.score-btn:hover { background: rgba(201,162,39,0.15); border-color: rgba(201,162,39,0.4); }
.score-btn.active {
  background: var(--fifa-gold);
  color: var(--fifa-navy);
  border-color: transparent;
}
.submit-btn {
  width: 100%;
  background: var(--fifa-gold);
  color: var(--fifa-navy);
  padding: 14px;
  border-radius: 4px;
  font-family: 'Inter', sans-serif;
  font-size: 13px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1px;
  border: none;
  cursor: pointer;
  transition: opacity 0.2s, background 0.3s;
}
.submit-btn:hover { opacity: 0.87; }
.submit-btn.locked { background: #1D9E75; }
#predict-result {
  margin-top: 16px;
  min-height: 28px;
  font-family: 'Inter', sans-serif;
  font-size: 14px;
  color: var(--fifa-silver);
  opacity: 0;
  transform: translateY(6px);
  transition: opacity 0.3s, transform 0.3s;
}
#predict-result.show { opacity: 1; transform: translateY(0); }

/* ==================== FOOTER ==================== */
footer {
  background: rgba(0,0,0,0.42);
  border-top: 1px solid rgba(201,162,39,0.18);
  padding: 40px 24px;
  text-align: center;
  position: relative;
  z-index: 2;
}
.footer-logo-wrap { margin-bottom: 16px; display: flex; justify-content: center; }
.footer-links {
  list-style: none;
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 24px;
  margin-bottom: 18px;
}
.footer-links a {
  font-family: 'Inter', sans-serif;
  font-size: 12px;
  color: var(--fifa-silver);
  text-decoration: none;
  transition: color 0.2s;
}
.footer-links a:hover { color: var(--fifa-gold); }
.footer-flags {
  font-size: 18px;
  margin-bottom: 16px;
  letter-spacing: 8px;
}
.footer-copy {
  font-family: 'Inter', sans-serif;
  font-size: 12px;
  color: rgba(255,255,255,0.22);
  max-width: 600px;
  margin: 0 auto;
  line-height: 1.6;
}

/* ==================== FOCUS STYLES ==================== */
*:focus-visible { outline: 2px solid #c9a227; outline-offset: 2px; }

/* ==================== FADE-UP ANIMATIONS ==================== */
.fade-up {
  opacity: 0;
  transform: translateY(28px);
  transition: opacity 0.55s ease, transform 0.55s ease;
}
.fade-up.in-view { opacity: 1; transform: translateY(0); }

.fade-left {
  opacity: 0;
  transform: translateX(-24px);
  transition: opacity 0.55s ease, transform 0.55s ease;
}
.fade-left.in-view { opacity: 1; transform: translateX(0); }

.t-event.fade-left {
  opacity: 0;
  transform: translateX(-20px);
  transition: opacity 0.5s ease, transform 0.5s ease;
}
.t-event.fade-left.in-view { opacity: 1; transform: translateX(0); }

/* ==================== REDUCED MOTION ==================== */
@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
  }
  html { scroll-behavior: auto; }
}

/* ==================== RESPONSIVE ==================== */
@media (max-width: 1024px) {
  .section { padding: 60px 24px; }
}

@media (max-width: 768px) {
  body { padding-top: 102px; }
  nav { padding: 0 20px; }
  .nav-links { display: none; }
  .hamburger { display: block; }
  .logo-section { display: none; }
  .section { padding: 48px 16px; }
  .stats-grid { grid-template-columns: repeat(3, 1fr); }
  .predictor-card { padding: 24px 16px; }
  #hero { padding: 20px 16px 60px; }
}

@media (max-width: 480px) {
  .banner-dots { display: none; }
  .stats-grid { grid-template-columns: repeat(2, 1fr); }
  .cd-block { padding: 12px 14px; min-width: 64px; }
  .cd-num { font-size: 40px; }
  .players-grid { grid-template-columns: repeat(2, 1fr); }
}

@media (max-width: 375px) {
  .hero-ctas { flex-direction: column; align-items: stretch; }
  .btn-primary, .btn-secondary { text-align: center; }
  .players-grid { grid-template-columns: 1fr; }
}

/* ==================== PULSING ANIMATIONS ==================== */
@media (prefers-reduced-motion: no-preference) {
  .pulse-dot {
    animation: pulseDot 0.9s ease-in-out infinite;
  }
  @keyframes pulseDot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.2; }
  }

  .ticker-status.live {
    animation: statusPulse 1.1s ease-in-out infinite;
  }
  @keyframes statusPulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .live-dot {
    animation: liveDotScale 1.2s ease-in-out infinite;
  }
  @keyframes liveDotScale {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.4); }
  }

  .hero-logo-wrap svg {
    animation: floatLogo 4s ease-in-out infinite;
  }
  @keyframes floatLogo {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }

  .scroll-line {
    animation: scrollAnim 2s ease-in-out infinite;
  }
  @keyframes scrollAnim {
    0%, 100% { transform: translateY(0); opacity: 0.4; }
    50% { transform: translateY(6px); opacity: 0.8; }
  }
}
</style>
</head>
<body>

<!-- ==================== CANVAS ==================== -->
<canvas id="ball-canvas" aria-hidden="true"></canvas>

<!-- ==================== NAVIGATION ==================== -->
<nav role="navigation" aria-label="Main navigation">
  <!-- FIFA 2026 Logo — Placement 1: NAV BAR -->
  <a href="#hero" onclick="navTo(event,'hero')" aria-label="FIFA World Cup 2026 Home">
    <svg class="logo-nav" viewBox="0 0 280 380" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="FIFA World Cup 2026 Logo">
      <defs>
        <linearGradient id="goldGrad" x1="0%" y1="0%" x2="0%" y2="100%">
          <stop offset="0%" stop-color="#f5d675"/>
          <stop offset="50%" stop-color="#c9a227"/>
          <stop offset="100%" stop-color="#a07a10"/>
        </linearGradient>
        <radialGradient id="trophyGrad" cx="50%" cy="40%" r="55%">
          <stop offset="0%" stop-color="#f5e88a"/>
          <stop offset="100%" stop-color="#c9a227"/>
        </radialGradient>
        <filter id="trophyShadow" x="-20%" y="-20%" width="140%" height="140%">
          <feDropShadow dx="0" dy="4" stdDeviation="8" flood-color="#c9a227" flood-opacity="0.7"/>
        </filter>
      </defs>
      <rect width="280" height="380" fill="#0a1628" rx="4"/>
      <rect width="278" height="378" x="1" y="1" fill="none" stroke="#c9a227" stroke-width="2" rx="4"/>
      <!-- "2" numeral -->
      <g fill="url(#goldGrad)">
        <rect x="60" y="20" width="160" height="18" rx="3"/>
        <rect x="182" y="20" width="38" height="80" rx="3"/>
        <rect x="60" y="80" width="160" height="18" rx="3"/>
        <rect x="60" y="80" width="38" height="80" rx="3"/>
        <rect x="60" y="140" width="160" height="18" rx="3"/>
      </g>
      <!-- "6" numeral -->
      <g fill="url(#goldGrad)">
        <rect x="60" y="168" width="160" height="18" rx="3"/>
        <rect x="60" y="168" width="38" height="82" rx="3"/>
        <rect x="60" y="228" width="160" height="18" rx="3"/>
        <rect x="182" y="228" width="38" height="60" rx="3"/>
        <rect x="60" y="268" width="160" height="18" rx="3"/>
      </g>
      <!-- Trophy overlay -->
      <g filter="url(#trophyShadow)" fill="url(#trophyGrad)">
        <!-- Base tiers -->
        <rect x="95" y="320" width="90" height="14" rx="2"/>
        <rect x="105" y="308" width="70" height="14" rx="2"/>
        <rect x="112" y="296" width="56" height="14" rx="2"/>
        <!-- Stem -->
        <rect x="128" y="220" width="24" height="78" rx="4"/>
        <!-- Cup bowl -->
        <path d="M100,150 Q85,185 85,215 Q85,225 140,228 Q195,225 195,215 Q195,185 180,150 Z"/>
        <!-- Figures with arms raised -->
        <path d="M116,110 Q113,130 115,148 L130,148 Q128,130 126,115 Z"/>
        <path d="M164,110 Q167,130 165,148 L150,148 Q152,130 154,115 Z"/>
        <!-- Globe at top -->
        <circle cx="140" cy="100" r="18"/>
        <!-- Left arm -->
        <path d="M113,125 Q100,115 95,108 Q98,104 102,106 Q106,118 116,122 Z"/>
        <!-- Right arm -->
        <path d="M167,125 Q180,115 185,108 Q182,104 178,106 Q174,118 164,122 Z"/>
      </g>
      <!-- FIFA wordmark -->
      <!-- Bebas Neue naturally has geometric/diagonal F bars -->
      <text x="140" y="348" text-anchor="middle" font-family="'Bebas Neue', sans-serif" font-size="38" fill="#ffffff" letter-spacing="4">FIFA</text>
      <!-- Host nations -->
      <text x="140" y="368" text-anchor="middle" font-family="'Inter', sans-serif" font-size="9" fill="#b0b8c8" letter-spacing="2">CANADA · MEXICO · USA</text>
    </svg>
  </a>

  <ul class="nav-links">
    <li><a href="#venues" onclick="navTo(event,'venues')" aria-label="Go to Venues section">Venues</a></li>
    <li><a href="#groups" onclick="navTo(event,'groups')" aria-label="Go to Groups section">Groups</a></li>
    <li><a href="#players" onclick="navTo(event,'players')" aria-label="Go to Stars section">Stars</a></li>
    <li><a href="#schedule" onclick="navTo(event,'schedule')" aria-label="Go to Schedule section">Schedule</a></li>
    <li><a href="#predictor" onclick="navTo(event,'predictor')" aria-label="Go to Predictor section">Predictor</a></li>
  </ul>

  <a href="https://www.ticketmaster.com/fifaworldcup2026" target="_blank" rel="noopener noreferrer"
     class="tickets-btn"
     aria-label="Get FIFA World Cup 2026 tickets on Ticketmaster (opens in new tab)">
    GET TICKETS ↗
  </a>

  <button class="hamburger" id="hamburger-btn" aria-label="Open navigation menu" aria-expanded="false">☰</button>
</nav>

<!-- Mobile Menu -->
<div class="mobile-menu" id="mobile-menu" role="navigation" aria-label="Mobile navigation">
  <a href="#venues" onclick="mobileNavTo(event,'venues')" aria-label="Go to Venues section">Venues</a>
  <a href="#groups" onclick="mobileNavTo(event,'groups')" aria-label="Go to Groups section">Groups</a>
  <a href="#players" onclick="mobileNavTo(event,'players')" aria-label="Go to Stars section">Stars</a>
  <a href="#schedule" onclick="mobileNavTo(event,'schedule')" aria-label="Go to Schedule section">Schedule</a>
  <a href="#predictor" onclick="mobileNavTo(event,'predictor')" aria-label="Go to Predictor section">Predictor</a>
</div>

<!-- ==================== LIVE SCORES BANNER ==================== -->
<div class="scores-banner" role="marquee" aria-label="Live match scores" aria-hidden="true">
  <div class="banner-anchor">
    <!-- FIFA 2026 Logo — Placement 3: LIVE SCORES BANNER -->
    <svg class="logo-ticker" viewBox="0 0 280 380" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <defs>
        <linearGradient id="goldGrad2" x1="0%" y1="0%" x2="0%" y2="100%">
          <stop offset="0%" stop-color="#f5d675"/>
          <stop offset="50%" stop-color="#c9a227"/>
          <stop offset="100%" stop-color="#a07a10"/>
        </linearGradient>
      </defs>
      <rect width="280" height="380" fill="#0a1628" rx="4"/>
      <rect width="278" height="378" x="1" y="1" fill="none" stroke="#c9a227" stroke-width="2" rx="4"/>
      <g fill="url(#goldGrad2)">
        <rect x="60" y="20" width="160" height="18" rx="3"/>
        <rect x="182" y="20" width="38" height="80" rx="3"/>
        <rect x="60" y="80" width="160" height="18" rx="3"/>
        <rect x="60" y="80" width="38" height="80" rx="3"/>
        <rect x="60" y="140" width="160" height="18" rx="3"/>
        <rect x="60" y="168" width="160" height="18" rx="3"/>
        <rect x="60" y="168" width="38" height="82" rx="3"/>
        <rect x="60" y="228" width="160" height="18" rx="3"/>
        <rect x="182" y="228" width="38" height="60" rx="3"/>
        <rect x="60" y="268" width="160" height="18" rx="3"/>
      </g>
      <text x="140" y="348" text-anchor="middle" font-family="'Bebas Neue', sans-serif" font-size="38" fill="#ffffff" letter-spacing="4">FIFA</text>
    </svg>
    <div class="pulse-dot"></div>
    <span class="banner-live-text">LIVE</span>
  </div>

  <div class="banner-ticker-area">
    <div id="ticker-item" aria-live="polite" aria-atomic="true"></div>
    <div class="banner-dots" id="banner-dots"></div>
  </div>
</div>

<!-- ==================== HERO SECTION ==================== -->
<section id="hero" aria-labelledby="hero-heading">
  <!-- Pitch overlay -->
  <svg class="pitch-overlay" viewBox="0 0 1440 900" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
    <!-- Vertical center line -->
    <line x1="720" y1="0" x2="720" y2="900" stroke="white" stroke-width="1"/>
    <!-- Center circle -->
    <circle cx="720" cy="450" r="120" fill="none" stroke="white" stroke-width="1"/>
    <!-- Center dot -->
    <circle cx="720" cy="450" r="5" fill="white"/>
    <!-- Halfway line -->
    <line x1="0" y1="450" x2="1440" y2="450" stroke="white" stroke-width="1"/>
    <!-- Left penalty box -->
    <rect x="0" y="270" width="165" height="360" fill="none" stroke="white" stroke-width="1"/>
    <!-- Right penalty box -->
    <rect x="1275" y="270" width="165" height="360" fill="none" stroke="white" stroke-width="1"/>
    <!-- Left 6-yard box -->
    <rect x="0" y="380" width="55" height="140" fill="none" stroke="white" stroke-width="1"/>
    <!-- Right 6-yard box -->
    <rect x="1385" y="380" width="55" height="140" fill="none" stroke="white" stroke-width="1"/>
    <!-- Corner arcs -->
    <path d="M0,20 A20,20 0 0,0 20,0" fill="none" stroke="white" stroke-width="1"/>
    <path d="M1420,0 A20,20 0 0,0 1440,20" fill="none" stroke="white" stroke-width="1"/>
    <path d="M0,880 A20,20 0 0,1 20,900" fill="none" stroke="white" stroke-width="1"/>
    <path d="M1420,900 A20,20 0 0,1 1440,880" fill="none" stroke="white" stroke-width="1"/>
  </svg>

  <div class="live-badge">
    <span class="live-dot" aria-hidden="true"></span>
    LIVE NOW · 2026 TOURNAMENT IN PROGRESS
  </div>

  <!-- FIFA 2026 Logo — Placement 2: HERO SECTION -->
  <div class="hero-logo-wrap">
    <svg class="logo-hero" viewBox="0 0 280 380" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="FIFA World Cup 2026 Official Logo">
      <defs>
        <linearGradient id="goldGrad3" x1="0%" y1="0%" x2="0%" y2="100%">
          <stop offset="0%" stop-color="#f5d675"/>
          <stop offset="50%" stop-color="#c9a227"/>
          <stop offset="100%" stop-color="#a07a10"/>
        </linearGradient>
        <radialGradient id="trophyGrad3" cx="50%" cy="40%" r="55%">
          <stop offset="0%" stop-color="#f5e88a"/>
          <stop offset="100%" stop-color="#c9a227"/>
        </radialGradient>
        <filter id="trophyShadow3" x="-20%" y="-20%" width="140%" height="140%">
          <feDropShadow dx="0" dy="4" stdDeviation="8" flood-color="#c9a227" flood-opacity="0.7"/>
        </filter>
      </defs>
      <rect width="280" height="380" fill="#0a1628" rx="4"/>
      <rect width="278" height="378" x="1" y="1" fill="none" stroke="#c9a227" stroke-width="2" rx="4"/>
      <g fill="url(#goldGrad3)">
        <rect x="60" y="20" width="160" height="18" rx="3"/>
        <rect x="182" y="20" width="38" height="80" rx="3"/>
        <rect x="60" y="80" width="160" height="18" rx="3"/>
        <rect x="60" y="80" width="38" height="80" rx="3"/>
        <rect x="60" y="140" width="160" height="18" rx="3"/>
        <rect x="60" y="168" width="160" height="18" rx="3"/>
        <rect x="60" y="168" width="38" height="82" rx="3"/>
        <rect x="60" y="228" width="160" height="18" rx="3"/>
        <rect x="182" y="228" width="38" height="60" rx="3"/>
        <rect x="60" y="268" width="160" height="18" rx="3"/>
      </g>
      <g filter="url(#trophyShadow3)" fill="url(#trophyGrad3)">
        <rect x="95" y="320" width="90" height="14" rx="2"/>
        <rect x="105" y="308" width="70" height="14" rx="2"/>
        <rect x="112" y="296" width="56" height="14" rx="2"/>
        <rect x="128" y="220" width="24" height="78" rx="4"/>
        <path d="M100,150 Q85,185 85,215 Q85,225 140,228 Q195,225 195,215 Q195,185 180,150 Z"/>
        <path d="M116,110 Q113,130 115,148 L130,148 Q128,130 126,115 Z"/>
        <path d="M164,110 Q167,130 165,148 L150,148 Q152,130 154,115 Z"/>
        <circle cx="140" cy="100" r="18"/>
        <path d="M113,125 Q100,115 95,108 Q98,104 102,106 Q106,118 116,122 Z"/>
        <path d="M167,125 Q180,115 185,108 Q182,104 178,106 Q174,118 164,122 Z"/>
      </g>
      <text x="140" y="348" text-anchor="middle" font-family="'Bebas Neue', sans-serif" font-size="38" fill="#ffffff" letter-spacing="4">FIFA</text>
      <text x="140" y="368" text-anchor="middle" font-family="'Inter', sans-serif" font-size="9" fill="#b0b8c8" letter-spacing="2">CANADA · MEXICO · USA</text>
    </svg>
  </div>

  <h1 class="hero-headline" id="hero-heading">WE ARE 26</h1>
  <p class="hero-sub">USA · CANADA · MEXICO · 2026</p>
  <p class="hero-flags" aria-hidden="true">🇺🇸 United States &nbsp;✦&nbsp; 🇨🇦 Canada &nbsp;✦&nbsp; 🇲🇽 Mexico</p>

  <div class="countdown" role="timer" aria-live="polite" aria-atomic="true" aria-label="Countdown to FIFA World Cup 2026">
    <div class="cd-block"><span class="cd-num" id="cd-days">000</span><span class="cd-label">Days</span></div>
    <div class="cd-block"><span class="cd-num" id="cd-hours">00</span><span class="cd-label">Hours</span></div>
    <div class="cd-block"><span class="cd-num" id="cd-mins">00</span><span class="cd-label">Minutes</span></div>
    <div class="cd-block"><span class="cd-num" id="cd-secs">00</span><span class="cd-label">Seconds</span></div>
  </div>

  <div class="hero-ctas">
    <a href="#groups" class="btn-primary" onclick="navTo(event,'groups')">EXPLORE THE DRAW</a>
    <a href="#predictor" class="btn-secondary" onclick="navTo(event,'predictor')">MAKE A PREDICTION</a>
  </div>

  <div class="scroll-indicator" aria-hidden="true">
    <span>SCROLL</span>
    <div class="scroll-line"></div>
  </div>
</section>

<!-- ==================== STATS STRIP ==================== -->
<div class="stats-strip" id="stats-strip">
  <!-- FIFA 2026 Logo — Placement 4: STATS STRIP -->
  <div class="stats-logo-row">
    <svg class="logo-stamp" viewBox="0 0 280 380" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <defs>
        <linearGradient id="goldGrad4" x1="0%" y1="0%" x2="0%" y2="100%">
          <stop offset="0%" stop-color="#f5d675"/>
          <stop offset="50%" stop-color="#c9a227"/>
          <stop offset="100%" stop-color="#a07a10"/>
        </linearGradient>
      </defs>
      <rect width="280" height="380" fill="#0a1628" rx="4"/>
      <rect width="278" height="378" x="1" y="1" fill="none" stroke="#c9a227" stroke-width="2" rx="4"/>
      <g fill="url(#goldGrad4)">
        <rect x="60" y="20" width="160" height="18" rx="3"/>
        <rect x="182" y="20" width="38" height="80" rx="3"/>
        <rect x="60" y="80" width="160" height="18" rx="3"/>
        <rect x="60" y="80" width="38" height="80" rx="3"/>
        <rect x="60" y="140" width="160" height="18" rx="3"/>
        <rect x="60" y="168" width="160" height="18" rx="3"/>
        <rect x="60" y="168" width="38" height="82" rx="3"/>
        <rect x="60" y="228" width="160" height="18" rx="3"/>
        <rect x="182" y="228" width="38" height="60" rx="3"/>
        <rect x="60" y="268" width="160" height="18" rx="3"/>
      </g>
      <text x="140" y="348" text-anchor="middle" font-family="'Bebas Neue', sans-serif" font-size="38" fill="#ffffff" letter-spacing="4">FIFA</text>
    </svg>
  </div>
  <div class="stats-grid">
    <div class="stat-item fade-up">
      <span class="stat-num" data-target="48">0</span>
      <span class="stat-label">Teams</span>
    </div>
    <div class="stat-item fade-up">
      <span class="stat-num" data-target="104">0</span>
      <span class="stat-label">Matches</span>
    </div>
    <div class="stat-item fade-up">
      <span class="stat-num" data-target="16">0</span>
      <span class="stat-label">Host Cities</span>
    </div>
