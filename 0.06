  animation-delay: -6s;
}

/* Ball 22 */
.watermark-ball:nth-child(22) {
  top: 85%; left: 83%;
  animation: watermark-drift-c 23s ease-in-out infinite;
  animation-delay: -11s;
}

/* Ball 23 */
.watermark-ball:nth-child(23) {
  top: 92%; left: 5%;
  animation: watermark-drift-a 21s ease-in-out infinite;
