<!-- ==================== JAVASCRIPT ==================== -->
<script>
// ==================== ANIMATED CANVAS FOOTBALLS ====================
(function() {
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (prefersReducedMotion) return;

  const canvas = document.getElementById('ball-canvas');
  const ctx = canvas.getContext('2d');
  let W, H, rafId, paused = false;

  const balls = [
    { r: 16, vx: 0.6, vy: -0.8, rot: 0, rotSpeed: 0.022 },
    { r: 24, vx: -0.9, vy: 0.5, rot: 1, rotSpeed: -0.018 },
    { r: 32, vx: 0.4, vy: 1.2, rot: 2, rotSpeed: 0.015 },
    { r: 38, vx: -1.3, vy: -0.6, rot: 0.5, rotSpeed: 0.028 },
    { r: 44, vx: 1.1, vy: 0.9, rot: 1.5, rotSpeed: -0.020 },
  ];

  function resize() {
    W = canvas.width = window.innerWidth;
    H = canvas.height = window.innerHeight;
  }

  function initBallPositions() {
    balls.forEach(b => {
      b.x = Math.random() * W;
      b.y = Math.random() * H;
    });
  }

  function drawPentagon(ctx, cx, cy, size) {
    ctx.beginPath();
    for (let i = 0; i < 5; i++) {
      const angle = (i * 2 * Math.PI / 5) - Math.PI / 2;
      const px = cx + size * Math.cos(angle);
      const py = cy + size * Math.sin(angle);
      i === 0 ? ctx.moveTo(px, py) : ctx.lineTo(px, py);
    }
    ctx.closePath();
  }

  function drawBall(ctx, ball) {
    const { x, y, r, rot } = ball;
    ctx.save();
    ctx.translate(x, y);
    ctx.rotate(rot);

    // Shadow glow
    ctx.shadowBlur = 14;
    ctx.shadowColor = 'rgba(201,162,39,0.35)';

    // Main circle
    ctx.beginPath();
    ctx.arc(0, 0, r, 0, 2 * Math.PI);
    ctx.strokeStyle = 'rgba(201,162,39,0.65)';
    ctx.lineWidth = 1.5;
    ctx.stroke();

    // Pentagon centers
    const patchRadius = r * 0.52;
    const patchSize = r * 0.2;
    const centers = [
      [0, -patchRadius],
      [patchRadius * Math.cos(Math.PI / 10 * 2), patchRadius * Math.sin(Math.PI / 10 * 2)],
      [patchRadius * Math.cos(Math.PI / 10 * 6), patchRadius * Math.sin(Math.PI / 10 * 6)],
      [patchRadius * Math.cos(Math.PI / 10 * 10), patchRadius * Math.sin(Math.PI / 10 * 10)],
      [patchRadius * Math.cos(Math.PI / 10 * 14), patchRadius * Math.sin(Math.PI / 10 * 14)],
    ];

    // Lines connecting center to outer pentagons
    ctx.strokeStyle = 'rgba(201,162,39,0.2)';
    ctx.lineWidth = 0.7;
    for (let i = 1; i < 5; i++) {
      ctx.beginPath();
      ctx.moveTo(centers[0][0], centers[0][1]);
      ctx.lineTo(centers[i][0], centers[i][1]);
      ctx.stroke();
    }

    // Pentagon patches
    ctx.strokeStyle = 'rgba(201,162,39,0.4)';
    ctx.lineWidth = 1.0;
    centers.forEach(([cx, cy]) => {
      drawPentagon(ctx, cx, cy, patchSize);
      ctx.stroke();
    });

    ctx.restore();
  }

  function tick() {
    if (paused) return;
    ctx.clearRect(0, 0, W, H);
    balls.forEach(b => {
      b.x += b.vx;
      b.y += b.vy;
      b.rot += b.rotSpeed;
      // Edge wrap
      if (b.x < -b.r) b.x = W + b.r;
      if (b.x > W + b.r) b.x = -b.r;
      if (b.y < -b.r) b.y = H + b.r;
      if (b.y > H + b.r) b.y = -b.r;
      drawBall(ctx, b);
    });
    rafId = requestAnimationFrame(tick);
  }

  document.addEventListener('visibilitychange', () => {
    if (document.hidden) {
      paused = true;
      cancelAnimationFrame(rafId);
    } else {
      paused = false;
      tick();
    }
  });

  resize();
  initBallPositions();
  window.addEventListener('resize', resize);
  tick();
})();

// ==================== NAVIGATION ====================
function navTo(e, sectionId) {
  if (e) e.preventDefault();
  const target = document.getElementById(sectionId);
  if (!target) return;
  const navHeight = document.querySelector('nav').offsetHeight; // 64px
  const bannerHeight = 38;
  const gap = 12;
  const offset = navHeight + bannerHeight + gap;
  const top = target.getBoundingClientRect().top + window.pageYOffset - offset;
  window.scrollTo({ top: top, behavior: 'smooth' });
  // Immediately mark as active
  document.querySelectorAll('.nav-links a').forEach(a => {
    a.classList.toggle('active', a.getAttribute('href') === '#' + sectionId);
  });
}

function mobileNavTo(e, sectionId) {
  navTo(e, sectionId);
  // Close mobile menu
  document.getElementById('mobile-menu').classList.remove('open');
  const btn = document.getElementById('hamburger-btn');
  btn.setAttribute('aria-expanded', 'false');
}

// Hamburger
document.getElementById('hamburger-btn').addEventListener('click', function() {
  const menu = document.getElementById('mobile-menu');
  const isOpen = menu.classList.toggle('open');
  this.setAttribute('aria-expanded', String(isOpen));
  this.textContent = isOpen ? '✕' : '☰';
});

// Scroll effects
function highlightActiveNav() {
  const sections = ['venues', 'groups', 'players', 'schedule', 'predictor'];
  const navHeight = 64;
  const bannerHeight = 38;
  const trigger = navHeight + bannerHeight + 80;
  let current = '';
  sections.forEach(id => {
    const el = document.getElementById(id);
    if (!el) return;
    if (el.getBoundingClientRect().top <= trigger) {
      current = id;
    }
  });
  document.querySelectorAll('.nav-links a').forEach(a => {
    a.classList.toggle('active', a.getAttribute('href') === '#' + current);
  });
}

window.addEventListener('scroll', function() {
  // Nav shadow on scroll
  const nav = document.querySelector('nav');
  if (window.pageYOffset > 50) {
    nav.classList.add('scrolled');
  } else {
    nav.classList.remove('scrolled');
  }
  highlightActiveNav();
}, { passive: true });

// ==================== LIVE SCORES BANNER ====================
const matches = [
  { home: '🇦🇷 Argentina', score: '2 - 1', away: 'France 🇫🇷',   status: "LIVE 67'", live: true },
  { home: '🇧🇷 Brazil',    score: '3 - 0', away: 'Serbia 🇷🇸',   status: "LIVE 82'", live: true },
  { home: '🇩🇪 Germany',   score: '1 - 1', away: 'Spain 🇪🇸',    status: "LIVE 55'", live: true },
  { home: '🏴󠁧󠁢󠁥󠁮󠁧󠁿 England',  score: '2 - 0', away: 'Morocco 🇲🇦', status: "LIVE 71'", live: true },
  { home: '🇵🇹 Portugal',  score: '1 - 0', away: 'Japan 🇯🇵',    status: 'FT',        live: false },
  { home: '🇳🇱 Netherlands', score: '2 - 2', away: 'Mexico 🇲🇽', status: 'FT',        live: false },
  { home: '🇺🇸 USA',       score: '1 - 0', away: 'Canada 🇨🇦',  status: "LIVE 43'", live: true  },
  { home: '🇭🇷 Croatia',   score: '0 - 0', away: 'Belgium 🇧🇪', status: "LIVE 28'", live: true  },
];

let currentMatchIndex = 0;

function buildMatchHTML(item) {
  const statusClass = item.live ? 'live' : 'ft';
  return `
    <span class="ticker-team">${item.home}</span>
    <span class="ticker-score">${item.score}</span>
    <span class="ticker-team">${item.away}</span>
    <span class="ticker-status ${statusClass}">${item.status}</span>
  `;
}

function buildDots() {
  const dotsContainer = document.getElementById('banner-dots');
  dotsContainer.innerHTML = '';
  matches.forEach((_, i) => {
    const dot = document.createElement('div');
    dot.className = 'banner-dot' + (i === 0 ? ' active' : '');
    dotsContainer.appendChild(dot);
  });
}

function rotateBanner() {
  const el = document.getElementById('ticker-item');
  el.style.opacity = '0';
  setTimeout(() => {
    el.innerHTML = buildMatchHTML(matches[currentMatchIndex]);
    el.style.opacity = '1';
    // Update dots
    const dots = document.querySelectorAll('.banner-dot');
    dots.forEach((d, i) => d.classList.toggle('active', i === currentMatchIndex));
    currentMatchIndex = (currentMatchIndex + 1) % matches.length;
  }, 400);
}

buildDots();
rotateBanner();
setInterval(rotateBanner, 3500);

// ==================== COUNTDOWN TIMER ====================
function updateCountdown() {
  const target = new Date('2026-06-11T20:00:00Z').getTime();
  const now = new Date().getTime();
  const diff = target - now;

  if (diff <= 0) {
    document.getElementById('cd-days').textContent = '000';
    document.getElementById('cd-hours').textContent = '00';
    document.getElementById('cd-mins').textContent = '00';
    document.getElementById('cd-secs').textContent = '00';
    return;
  }

  const days = Math.floor(diff / (1000 * 60 * 60 * 24));
  const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
  const mins = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
  const secs = Math.floor((diff % (1000 * 60)) / 1000);

  document.getElementById('cd-days').textContent = String(days).padStart(3, '0');
  document.getElementById('cd-hours').textContent = String(hours).padStart(2, '0');
  document.getElementById('cd-mins').textContent = String(mins).padStart(2, '0');
  document.getElementById('cd-secs').textContent = String(secs).padStart(2, '0');
}
updateCountdown();
setInterval(updateCountdown, 1000);

// ==================== STATS COUNTER ====================
function easeOutCubic(t) { return 1 - Math.pow(1 - t, 3); }

function animateCounter(el, target, duration) {
  const start = performance.now();
  function step(now) {
    const elapsed = now - start;
    const progress = Math.min(elapsed / duration, 1);
    const eased = easeOutCubic(progress);
    el.textContent = Math.round(eased * target);
    if (progress < 1) requestAnimationFrame(step);
    else el.textContent = target;
  }
  requestAnimationFrame(step);
}

const statsObserver = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      const counters = entry.target.querySelectorAll('[data-target]');
      counters.forEach(el => {
        const target = parseInt(el.getAttribute('data-target'), 10);
        animateCounter(el, target, 1600);
      });
      statsObserver.unobserve(entry.target);
    }
  });
}, { threshold: 0.2 });

const statsStrip = document.getElementById('stats-strip');
if (statsStrip) statsObserver.observe(statsStrip);

// ==================== GROUPS EXPAND ====================
let groupsExpanded = false;
function toggleGroups() {
  groupsExpanded = !groupsExpanded;
  const hidden = document.querySelectorAll('.hidden-group');
  hidden.forEach(el => {
    el.style.display = groupsExpanded ? 'block' : 'none';
  });
  const btn = document.getElementById('expand-btn');
  btn.textContent = groupsExpanded ? 'SHOW LESS ↑' : 'VIEW ALL 12 GROUPS ↓';
  btn.setAttribute('aria-expanded', String(groupsExpanded));
}

// ==================== PREDICTOR ====================
let selectedScore = null;

function pickScore(btn, score) {
  selectedScore = score;
  document.querySelectorAll('.score-btn').forEach(b => {
    b.classList.remove('active');
    b.setAttribute('aria-pressed', 'false');
  });
  btn.classList.add('active');
  btn.setAttribute('aria-pressed', 'true');
}

function submitPrediction() {
  const result = document.getElementById('predict-result');
  const submitBtn = document.getElementById('submit-btn');

  if (!selectedScore) {
    result.textContent = 'Please pick a score first ⚽';
    result.classList.add('show');
    return;
  }

  const parts = selectedScore.split('-').map(Number);
  const a = parts[0], b = parts[1];
  let message = '';

  if (a > b) {
    message = '🇦🇷 Argentina win! The Albiceleste faithful will love you.';
  } else if (b > a) {
    message = '🇫🇷 France take it! Vive la France — Les Bleus march on.';
  } else {
    message = '⚖️ All square! You\'re predicting extra-time drama.';
  }

  result.textContent = message;
  result.classList.add('show');
  submitBtn.textContent = '✓ Prediction Locked!';
  submitBtn.classList.add('locked');
}

// ==================== INTERSECTION OBSERVER — FADE ANIMATIONS ====================
const fadeObserver = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      entry.target.classList.add('in-view');
      fadeObserver.unobserve(entry.target);
    }
  });
}, { threshold: 0.12 });

// Apply stagger to sibling groups
function setupFadeGroup(selector) {
  const elements = document.querySelectorAll(selector);
  elements.forEach((el, index) => {
    // Find siblings within same parent for stagger
    const siblings = el.parentElement.querySelectorAll(selector);
    let siblingIndex = 0;
    siblings.forEach((sib, i) => { if (sib === el) siblingIndex = i; });
    el.style.transitionDelay = `${siblingIndex * 0.08}s`;
    fadeObserver.observe(el);
  });
}

// Apply stagger delays per parent container
function applyStaggeredObserver(parentSelector, childSelector) {
  const parents = document.querySelectorAll(parentSelector);
  parents.forEach(parent => {
    const children = parent.querySelectorAll(childSelector);
    children.forEach((child, index) => {
      child.style.transitionDelay = `${index * 0.08}s`;
      fadeObserver.observe(child);
    });
  });
}

// Venue cards
applyStaggeredObserver('.venues-grid', '.venue-card.fade-up');
// Group cards
applyStaggeredObserver('.groups-grid', '.group-card.fade-up');
// Player cards
applyStaggeredObserver('.players-grid', '.player-card.fade-up');
// Stat items
applyStaggeredObserver('.stats-grid', '.stat-item.fade-up');
// Timeline events
const timelineEvents = document.querySelectorAll('.t-event.fade-left');
timelineEvents.forEach((el, index) => {
  el.style.transitionDelay = `${index * 0.1}s`;
  fadeObserver.observe(el);
});
// Section brand rows
document.querySelectorAll('.section-brand-row.fade-left').forEach(el => {
  fadeObserver.observe(el);
});
// Predictor card
document.querySelectorAll('.predictor-card.fade-up').forEach(el => {
  fadeObserver.observe(el);
});
</script>
</body>
</html>
