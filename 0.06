/*
 * Watermark ball size and opacity tuning
 * Smaller background footballs: 60–120px, opacity 0.06–0.10
 * Matches the established watermark aesthetic
 */

/* ── Watermark layer container ── */
.watermark-layer {
  position: fixed;
  inset: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 0;
  overflow: hidden;
}

/* ── Base watermark ball ── */
.watermark-ball {
  position: absolute;
  background-image: url('https://upload.wikimedia.org/wikipedia/commons/thumb/d/d3/Soccerball.svg/240px-Soccerball.svg.png');
  background-size: cover;
  background-repeat: no-repeat;
  border-radius: 50%;
  will-change: transform, opacity;
  pointer-events: none;
}

/* ── Size tiers (60 px – 120 px) ── */
.watermark-ball--xs  { width:  60px; height:  60px; }
.watermark-ball--sm  { width:  75px; height:  75px; }
.watermark-ball--md  { width:  90px; height:  90px; }
.watermark-ball--lg  { width: 105px; height: 105px; }
.watermark-ball--xl  { width: 120px; height: 120px; }

/* ── Opacity tiers (0.06 – 0.10) ── */
.watermark-ball--opacity-06  { opacity: 0.06; }
.watermark-ball--opacity-07  { opacity: 0.07; }
.watermark-ball--opacity-08  { opacity: 0.08; }
.watermark-ball--opacity-09  { opacity: 0.09; }
.watermark-ball--opacity-10  { opacity: 0.10; }

/* ── Float / drift animations ── */
@keyframes watermark-drift-a {
  0%   { transform: translate(0,    0)    rotate(0deg); }
  25%  { transform: translate(18px, -22px) rotate(90deg); }
  50%  { transform: translate(-12px, 30px) rotate(180deg); }
  75%  { transform: translate(25px,  15px) rotate(270deg); }
  100% { transform: translate(0,    0)    rotate(360deg); }
}

@keyframes watermark-drift-b {
  0%   { transform: translate(0,    0)    rotate(0deg); }
  33%  { transform: translate(-20px, 25px) rotate(120deg); }
  66%  { transform: translate(15px, -18px) rotate(240deg); }
  100% { transform: translate(0,    0)    rotate(360deg); }
}

@keyframes watermark-drift-c {
  0%   { transform: translate(0,    0)    rotate(0deg); }
  20%  { transform: translate(10px, -30px) rotate(72deg); }
  40%  { transform: translate(28px,  10px) rotate(144deg); }
  60%  { transform: translate(-15px, 20px) rotate(216deg); }
  80%  { transform: translate(-25px, -10px) rotate(288deg); }
  100% { transform: translate(0,    0)    rotate(360deg); }
}

@keyframes watermark-drift-d {
  0%   { transform: translate(0,    0)    rotate(0deg); }
  50%  { transform: translate(-30px, -20px) rotate(180deg); }
  100% { transform: translate(0,    0)    rotate(360deg); }
}

/* ── Per-ball position & animation assignments ── */

/* Ball 1 */
.watermark-ball:nth-child(1) {
  top: 8%; left: 5%;
  animation: watermark-drift-a 18s ease-in-out infinite;
}

/* Ball 2 */
.watermark-ball:nth-child(2) {
  top: 15%; left: 22%;
  animation: watermark-drift-b 22s ease-in-out infinite;
  animation-delay: -4s;
}

/* Ball 3 */
.watermark-ball:nth-child(3) {
  top: 5%; left: 45%;
  animation: watermark-drift-c 26s ease-in-out infinite;
  animation-delay: -8s;
}

/* Ball 4 */
.watermark-ball:nth-child(4) {
  top: 10%; left: 68%;
  animation: watermark-drift-d 20s ease-in-out infinite;
  animation-delay: -2s;
}

/* Ball 5 */
.watermark-ball:nth-child(5) {
  top: 8%; left: 88%;
  animation: watermark-drift-a 24s ease-in-out infinite;
  animation-delay: -6s;
}

/* Ball 6 */
.watermark-ball:nth-child(6) {
  top: 28%; left: 3%;
  animation: watermark-drift-c 19s ease-in-out infinite;
  animation-delay: -11s;
}

/* Ball 7 */
.watermark-ball:nth-child(7) {
  top: 32%; left: 30%;
  animation: watermark-drift-b 28s ease-in-out infinite;
  animation-delay: -15s;
}

/* Ball 8 */
.watermark-ball:nth-child(8) {
