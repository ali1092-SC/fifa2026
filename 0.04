<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FIFA World Cup 2026 - Match Predictor</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #0a0a0a 0%, #1a1a2e 50%, #0a0a0a 100%);
            color: #ffffff;
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* Soccer ball background decoration */
        .bg-decoration {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 0;
            overflow: hidden;
        }

        .soccer-ball {
            position: absolute;
            border-radius: 50%;
            background: radial-gradient(circle at 35% 35%, #ffffff, #cccccc);
            animation: float 8s ease-in-out infinite;
        }

        .soccer-ball::before {
            content: '⚽';
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            font-size: 0.8em;
        }

        /* Depth layers — back layer: small, very faint */
        .soccer-ball.depth-back {
            opacity: 0.04;
            z-index: 0;
        }

        /* Mid layer: medium size, moderate opacity */
        .soccer-ball.depth-mid {
            opacity: 0.08;
            z-index: 1;
        }

        /* Front layer: larger balls, more visible */
        .soccer-ball.depth-front {
            opacity: 0.13;
            z-index: 2;
        }

        @keyframes float {
            0%, 100% { transform: translateY(0px) rotate(0deg); }
            33% { transform: translateY(-20px) rotate(120deg); }
            66% { transform: translateY(10px) rotate(240deg); }
        }

        @keyframes floatReverse {
            0%, 100% { transform: translateY(0px) rotate(0deg); }
            33% { transform: translateY(15px) rotate(-120deg); }
            66% { transform: translateY(-10px) rotate(-240deg); }
        }

        @keyframes floatSlow {
            0%, 100% { transform: translateY(0px) rotate(0deg); }
            50% { transform: translateY(-25px) rotate(180deg); }
        }

        @keyframes floatDrift {
            0%, 100% { transform: translateY(0px) translateX(0px) rotate(0deg); }
            25% { transform: translateY(-15px) translateX(8px) rotate(90deg); }
            50% { transform: translateY(-8px) translateX(-6px) rotate(180deg); }
            75% { transform: translateY(12px) translateX(4px) rotate(270deg); }
        }

        @keyframes floatDriftReverse {
            0%, 100% { transform: translateY(0px) translateX(0px) rotate(0deg); }
            25% { transform: translateY(12px) translateX(-8px) rotate(-90deg); }
            50% { transform: translateY(6px) translateX(10px) rotate(-180deg); }
            75% { transform: translateY(-14px) translateX(-4px) rotate(-270deg); }
        }

        /* Main container */
        .container {
            position: relative;
            z-index: 1;
            max-width: 1400px;
            margin: 0 auto;
            padding: 20px;
        }

        /* Header */
        .header {
            text-align: center;
            padding: 40px 20px;
            border-bottom: 1px solid rgba(255,255,255,0.1);
            margin-bottom: 30px;
        }

        .header h1 {
            font-size: clamp(2rem, 5vw, 3.5rem);
            font-weight: 900;
            background: linear-gradient(135deg, #FFD700, #FF6B35, #FFD700);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            text-transform: uppercase;
            letter-spacing: 3px;
            margin-bottom: 10px;
        }

        .header p {
            font-size: 1.1rem;
            color: rgba(255,255,255,0.6);
        }

        /* Navigation Tabs */
        .nav-tabs {
            display: flex;
            justify-content: center;
            gap: 10px;
            margin-bottom: 30px;
            flex-wrap: wrap;
        }

        .nav-tab {
            padding: 12px 24px;
            border: 2px solid rgba(255,215,0,0.3);
            background: rgba(255,255,255,0.05);
            color: rgba(255,255,255,0.7);
            border-radius: 30px;
            cursor: pointer;
            transition: all 0.3s ease;
            font-size: 0.9rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .nav-tab:hover {
            border-color: #FFD700;
            color: #FFD700;
            background: rgba(255,215,0,0.1);
        }

        .nav-tab.active {
            background: linear-gradient(135deg, #FFD700, #FF6B35);
            border-color: transparent;
            color: #000000;
        }

        /* Section styling */
        .section {
            display: none;
        }

        .section.active {
            display: block;
        }

        /* Cards grid */
        .cards-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        /* Match Card */
        .match-card {
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 16px;
            padding: 20px;
            transition: all 0.3s ease;
            cursor: pointer;
        }

        .match-card:hover {
            background: rgba(255,255,255,0.08);
            border-color: rgba(255,215,0,0.3);
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.3);
        }

        .match-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
            font-size: 0.75rem;
            color: rgba(255,255,255,0.5);
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .match-badge {
            background: rgba(255,215,0,0.1);
            color: #FFD700;
            padding: 3px 10px;
            border-radius: 20px;
            font-weight: 700;
        }

        .teams-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 15px;
        }

        .team {
            text-align: center;
            flex: 1;
        }

        .team-flag {
            font-size: 2.5rem;
            margin-bottom: 8px;
            display: block;
        }

        .team-name {
            font-size: 0.85rem;
            font-weight: 600;
            color: rgba(255,255,255,0.9);
        }

        .vs-divider {
            font-size: 1.2rem;
            font-weight: 900;
            color: rgba(255,255,255,0.3);
            padding: 0 10px;
        }

        .prediction-bar {
            background: rgba(255,255,255,0.1);
            border-radius: 10px;
            height: 8px;
            overflow: hidden;
            margin-bottom: 8px;
        }

        .prediction-fill {
            height: 100%;
            border-radius: 10px;
            background: linear-gradient(90deg, #FFD700, #FF6B35);
            transition: width 0.8s ease;
        }

        .prediction-labels {
            display: flex;
            justify-content: space-between;
            font-size: 0.75rem;
            color: rgba(255,255,255,0.5);
        }

        /* Group standings table */
        .group-card {
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 16px;
            padding: 20px;
            margin-bottom: 20px;
        }

        .group-title {
            font-size: 1.1rem;
            font-weight: 700;
            color: #FFD700;
            margin-bottom: 15px;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        .standings-table {
            width: 100%;
            border-collapse: collapse;
        }

        .standings-table th {
            text-align: left;
            padding: 8px 12px;
            font-size: 0.7rem;
            color: rgba(255,255,255,0.4);
            text-transform: uppercase;
            letter-spacing: 1px;
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }

        .standings-table td {
            padding: 10px 12px;
            font-size: 0.85rem;
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }

        .standings-table tr:last-child td {
            border-bottom: none;
        }

        .rank-badge {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 22px;
            height: 22px;
            border-radius: 50%;
            font-size: 0.75rem;
            font-weight: 700;
            background: rgba(255,255,255,0.1);
            margin-right: 8px;
        }

        .rank-1, .rank-2 {
            background: rgba(255,215,0,0.2);
            color: #FFD700;
        }

        /* Bracket visualization */
        .bracket-container {
            overflow-x: auto;
            padding: 20px 0;
        }

        .bracket-round {
            display: inline-flex;
            flex-direction: column;
            justify-content: space-around;
            min-width: 200px;
            vertical-align: top;
        }

        .bracket-match {
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 8px;
            padding: 10px 15px;
            margin: 8px;
            font-size: 0.85rem;
        }

        .bracket-team {
            padding: 4px 0;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .bracket-team.winner {
            color: #FFD700;
            font-weight: 700;
        }

        /* Stats cards */
        .stat-card {
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 16px;
            padding: 25px;
            text-align: center;
        }

        .stat-value {
            font-size: 2.5rem;
            font-weight: 900;
            background: linear-gradient(135deg, #FFD700, #FF6B35);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .stat-label {
            font-size: 0.85rem;
            color: rgba(255,255,255,0.5);
            margin-top: 5px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        /* Predictor form */
        .predictor-card {
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 16px;
            padding: 30px;
            max-width: 600px;
            margin: 0 auto;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            display: block;
            font-size: 0.85rem;
            color: rgba(255,255,255,0.6);
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .form-group select {
            width: 100%;
            padding: 12px 16px;
            background: rgba(255,255,255,0.08);
            border: 1px solid rgba(255,255,255,0.15);
            border-radius: 8px;
            color: #ffffff;
            font-size: 1rem;
            cursor: pointer;
            appearance: none;
            -webkit-appearance: none;
        }

        .form-group select option {
            background: #1a1a2e;
            color: #ffffff;
        }

        .predict-btn {
            width: 100%;
            padding: 15px;
            background: linear-gradient(135deg, #FFD700, #FF6B35);
            border: none;
            border-radius: 10px;
            color: #000000;
            font-size: 1.1rem;
            font-weight: 700;
            cursor: pointer;
            text-transform: uppercase;
            letter-spacing: 2px;
            transition: all 0.3s ease;
        }

        .predict-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(255,215,0,0.3);
        }

        .prediction-result {
            margin-top: 25px;
            padding: 20px;
            background: rgba(255,215,0,0.05);
            border: 1px solid rgba(255,215,0,0.2);
            border-radius: 12px;
            display: none;
        }

        .prediction-result.show {
            display: block;
        }

        .result-winner {
            font-size: 1.5rem;
            font-weight: 900;
            color: #FFD700;
            text-align: center;
            margin-bottom: 15px;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .cards-grid {
                grid-template-columns: 1fr;
            }

            .nav-tabs {
                gap: 8px;
            }

            .nav-tab {
                padding: 10px 16px;
                font-size: 0.8rem;
            }
        }
    </style>
</head>
<body>

    <!-- Background Soccer Balls -->
    <!-- Depth layers:
         depth-back  → opacity 0.04, z-index 0 (small balls, ~20–30px, very faint, deep background)
         depth-mid   → opacity 0.08, z-index 1 (medium balls, ~35–55px, mid-ground)
         depth-front → opacity 0.13, z-index 2 (larger balls, ~60–85px, subtle foreground)
    -->
    <div class="bg-decoration">

        <!-- ── FRONT LAYER — large, opacity 0.13, z-index 2 ── -->
        <!-- top-left quadrant -->
        <div class="soccer-ball depth-front" style="width:80px;height:80px;top:4%;left:3%;animation:float 9s ease-in-out infinite;animation-delay:0s;"></div>
        <!-- top-right quadrant -->
        <div class="soccer-ball depth-front" style="width:75px;height:75px;top:8%;left:87%;animation:floatReverse 10s ease-in-out infinite;animation-delay:-3s;"></div>
        <!-- center-left -->
        <div class="soccer-ball depth-front" style="width:70px;height:70px;top:42%;left:6%;animation:floatDrift 12s ease-in-out infinite;animation-delay:-5s;"></div>
        <!-- center-right -->
        <div class="soccer-ball depth-front" style="width:85px;height:85px;top:38%;left:89%;animation:floatDriftReverse 11s ease-in-out infinite;animation-delay:-1s;"></div>
        <!-- bottom-left quadrant -->
        <div class="soccer-ball depth-front" style="width:72px;height:72px;top:72%;left:4%;animation:floatReverse 13s ease-in-out infinite;animation-delay:-4s;"></div>
        <!-- bottom-right quadrant -->
        <div class="soccer-ball depth-front" style="width:78px;height:78px;top:78%;left:85%;animation:float 9s ease-in-out infinite;animation-delay:-7s;"></div>
        <!-- bottom-center -->
        <div class="soccer-ball depth-front" style="width:68px;height:68px;top:88%;left:48%;animation:floatSlow 14s ease-in-out infinite;animation-delay:-9s;"></div>

        <!-- ── MID LAYER — medium, opacity 0.08, z-index 1 ── -->
        <!-- top band spread -->
        <div class="soccer-ball depth-mid" style="width:50px;height:50px;top:2%;left:22%;animation:floatSlow 13s ease-in-out infinite;animation-delay:-2s;"></div>
        <div class="soccer-ball depth-mid" style="width:45px;height:45px;top:6%;left:55%;animation:float 11s ease-in-out infinite;animation-delay:-6s;"></div>
        <div class="soccer-ball depth-mid" style="width:55px;height:55px;top:12%;left:72%;animation:floatReverse 10s ease-in-out infinite;animation-delay:-8s;"></div>
        <!-- left column -->
        <div class="soccer-ball depth-mid" style="width:48px;height:48px;top:28%;left:14%;animation:floatDrift 12s ease-in-out infinite;animation-delay:-3s;"></div>
        <div class="soccer-ball depth-mid" style="width:52px;height:52px;top:55%;left:18%;animation:floatSlow 15s ease-in-out infinite;animation-delay:-10s;"></div>
        <!-- right column -->
        <div class="soccer-ball depth-mid" style="width:46px;height:46px;top:25%;left:80%;animation:float 10s ease-in-out infinite;animation-delay:-1s;"></div>
        <div class="soccer-ball depth-mid" style="width:54px;height:54px;top:60%;left:76%;animation:floatDriftReverse 13s ease-in-out infinite;animation-delay:-5s;"></div>
        <!-- center spread -->
        <div class="soccer-ball depth-mid" style="width:40px;height:40px;top:22%;left:40%;animation:floatReverse 11s ease-in-out infinite;animation-delay:-7s;"></div>
        <div class="soccer-ball depth-mid" style="width:44px;height:44px;top:48%;left:62%;animation:floatDrift 14s ease-in-out infinite;animation-delay:-4s;"></div>
        <!-- bottom band -->
        <div class="soccer-ball depth-mid" style="width:50px;height:50px;top:82%;left:32%;animation:float 12s ease-in-out infinite;animation-delay:-6s;"></div>
        <div class="soccer-ball depth-mid" style="width:42px;height:42px;top:92%;left:68%;animation:floatSlow 10s ease-in-out infinite;animation-delay:-2s;"></div>

        <!-- ── BACK LAYER — small, opacity 0.04, z-index 0 ── -->
        <!-- scattered across all quadrants for texture -->
        <div class="soccer-ball depth-back" style="width:28px;height:28px;top:1%;left:35%;animation:floatSlow 16s ease-in-out infinite;animation-delay:-3s;"></div>
        <div class="soccer-ball depth-back" style="width:22px;height:22px;top:10%;left:10%;animation:floatDrift 18s ease-in-out infinite;animation-delay:-11s;"></div>
        <div class="soccer-ball depth-back" style="width:30px;height:30px;top:18%;left:92%;animation:floatReverse 15s ease-in-out infinite;animation-delay:-7s;"></div>
        <div class="soccer-ball depth-back" style="width:24px;height:24px;top:32%;left:50%;animation:float 17s ease-in-out infinite;animation-delay:-9s;"></div>
        <div class="soccer-ball depth-back" style="width:26px;height:26px;top:45%;left:30%;animation:floatDriftReverse 19s ease-in-out infinite;animation-delay:-4s;"></div>
        <div class="soccer-ball depth-back" style="width:20px;height:20px;top:52%;left:44%;animation:floatSlow 16s ease-in-out infinite;animation-delay:-13s;"></div>
        <div class="soccer-ball depth-back" style="width:25px;height:25px;top:65%;left:58%;animation:floatDrift 20s ease-in-out infinite;animation-delay:-6s;"></div>
        <div class="soccer-ball depth-back" style="width:29px;height:29px;top:75%;left:20%;animation:float 14s ease-in-out infinite;animation-delay:-2s;"></div>
        <div class="soccer-ball depth-back" style="width:23px;height:23px;top:85%;left:72%;animation:floatReverse 17s ease-in-out infinite;animation-delay:-8s;"></div>
        <div class="soccer-ball depth-back" style="width:27px;height:27px;top:95%;left:10%;animation:floatDriftReverse 21s ease-in-out infinite;animation-delay:-15s;"></div>
        <div class="soccer-ball depth-back" style="width:21px;height:21px;top:35%;left:95%;animation:floatSlow 18s ease-in-out infinite;animation-delay:-5s;"></div>
        <div class="soccer-ball depth-back" style="width:30px;height:30px;top:68%;left:38%;animation:floatDrift 15s ease-in-out infinite;animation-delay:-12s;"></div>

    </div>

    <div class="container">
        <!-- Header -->
        <div class="header">
            <h1>⚽ FIFA World Cup 2026</h1>
            <p>Match Predictor & Tournament Tracker</p>
        </div>

        <!-- Navigation -->
        <div class="nav-tabs">
            <div class="nav-tab active" onclick="showSection('predictor')">🎯 Predictor</div>
            <div class="nav-tab" onclick="showSection('matches')">📅 Matches</div>
            <div class="nav-tab" onclick="showSection('groups')">📊 Groups</div>
            <div class="nav-tab" onclick="showSection('bracket')">🏆 Bracket</div>
            <div class="nav-tab" onclick="showSection('stats')">📈 Stats</div>
        </div>

        <!-- Predictor Section -->
        <div id="predictor" class="section active">
            <div class="predictor-card">
                <h2 style="text-align:center;margin-bottom:25px;font-size:1.5rem;">Match Outcome Predictor</h2>
                <div class="form-group">
                    <label>Home Team</label>
                    <select id="homeTeam">
                        <option value="">Select Team...</option>
                        <option value="Brazil">🇧🇷 Brazil</option>
                        <option value="Argentina">🇦🇷 Argentina</option>
                        <option value="France">🇫🇷 France</option>
                        <option value="England">🏴󠁧󠁢󠁥󠁮󠁧󠁿 England</option>
                        <option value="Spain">🇪🇸 Spain</option>
                        <option value="Germany">🇩🇪 Germany</option>
                        <option value="Portugal">🇵🇹 Portugal</option>
                        <option value="Netherlands">🇳🇱 Netherlands</option>
                        <option value="USA">🇺🇸 USA</option>
                        <option value="Mexico">🇲🇽 Mexico</option>
                        <option value="Canada">🇨🇦 Canada</option>
                        <option value="Morocco">🇲🇦 Morocco</option>
                        <option value="Japan">🇯🇵 Japan</option>
                        <option value="South Korea">🇰🇷 South Korea</option>
                        <option value="Australia">🇦🇺 Australia</option>
                        <option value="Senegal">🇸🇳 Senegal</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Away Team</label>
                    <select id="awayTeam">
                        <option value="">Select Team...</option>
                        <option value="Brazil">🇧🇷 Brazil</option>
                        <option value="Argentina">🇦🇷 Argentina</option>
                        <option value="France">🇫🇷 France</option>
                        <option value="England">🏴󠁧󠁢󠁥󠁮󠁧󠁿 England</option>
                        <option value="Spain">🇪🇸 Spain</option>
                        <option value="Germany">🇩🇪 Germany</option>
                        <option value="Portugal">🇵🇹 Portugal</option>
                        <option value="Netherlands">🇳🇱 Netherlands</option>
                        <option value="USA">🇺🇸 USA</option>
                        <option value="Mexico">🇲🇽 Mexico</option>
                        <option value="Canada">🇨🇦 Canada</option>
                        <option value="Morocco">🇲🇦 Morocco</option>
                        <option value="Japan">🇯🇵 Japan</option>
                        <option value="South Korea">🇰🇷 South Korea</option>
                        <option value="Australia">🇦🇺 Australia</option>
                        <option value="Senegal">🇸🇳 Senegal</option>
                    </select>
                </div>
                <button class="predict-btn" onclick="predictMatch()">⚡ Predict Match</button>
                <div id="predictionResult" class="prediction-result">
                    <div class="result-winner" id="resultWinner"></div>
                    <div id="resultBars"></div>
                </div>
            </div>
        </div>

        <!-- Matches Section -->
        <div id="matches" class="section">
            <div class="cards-grid" id="matchesGrid"></div>
        </div>

        <!-- Groups Section -->
        <div id="groups" class="section">
            <div id="groupsContainer"></div>
        </div>

        <!-- Bracket Section -->
        <div id="bracket" class="section">
            <div style="text-align:center;padding:40px;color:rgba(255,255,255,0.5);">
                <div style="font-size:3rem;margin-bottom:15px;">🏆</div>
                <div style="font-size:1.2rem;margin-bottom:10px;">Tournament Bracket</div>
                <div style="font-size:0.9rem;">Bracket will populate as group stage concludes</div>
                <div class="bracket-container" style="margin-top:30px;" id="bracketContainer"></div>
            </div>
        </div>

        <!-- Stats Section -->
        <div id="stats" class="section">
            <div class="cards-grid" id="statsGrid"></div>
        </div>
    </div>

    <script>
        // Tournament data
        const teams = {
            'Brazil': { rating: 92, fifa_rank: 1, style: 'attacking' },
            'Argentina': { rating: 91, fifa_rank: 2, style: 'balanced' },
            'France': { rating: 90, fifa_rank: 3, style: 'counter' },
            'England': { rating: 87, fifa_rank: 4, style: 'balanced' },
            'Spain': { rating: 88, fifa_rank: 5, style: 'possession' },
            'Germany': { rating: 85, fifa_rank: 6, style: 'pressing' },
            'Portugal': { rating: 86, fifa_rank: 7, style: 'attacking' },
            'Netherlands': { rating: 84, fifa_rank: 8, style: 'pressing' },
            'USA': { rating: 75, fifa_rank: 13, style: 'counter' },
            'Mexico': { rating: 73, fifa_rank: 15, style: 'defensive' },
            'Canada': { rating: 72, fifa_rank: 16, style: 'balanced' },
            'Morocco': { rating: 76, fifa_rank: 12, style: 'defensive' },
            'Japan': { rating: 78, fifa_rank: 10, style: 'pressing' },
            'South Korea': { rating: 75, fifa_rank: 14, style: 'counter' },
            'Australia': { rating: 71, fifa_rank: 17, style: 'balanced' },
            'Senegal': { rating: 77, fifa_rank: 11, style: 'attacking' }
        };

        const groups = {
            'A': ['USA', 'Mexico', 'Canada', 'Morocco'],
            'B': ['Brazil', 'Argentina', 'Japan', 'South Korea'],
            'C': ['France', 'Spain', 'Germany', 'Senegal'],
            'D': ['England', 'Portugal', 'Netherlands', 'Australia']
        };

        const sampleMatches = [
            { home: 'Brazil', away: 'Argentina', group: 'B', date: 'Jun 15' },
            { home: 'France', away: 'Spain', group: 'C', date: 'Jun 16' },
            { home: 'USA', away: 'Mexico', group: 'A', date: 'Jun 17' },
            { home: 'England', away: 'Portugal', group: 'D', date: 'Jun 18' },
            { home: 'Germany', away: 'Senegal', group: 'C', date: 'Jun 19' },
            { home: 'Japan', away: 'South Korea', group: 'B', date: 'Jun 20' },
            { home: 'Canada', away: 'Morocco', group: 'A', date: 'Jun 21' },
            { home: 'Netherlands', away: 'Australia', group: 'D', date: 'Jun 22' },
        ];

        // Prediction logic
        function predictMatch() {
            const home = document.getElementById('homeTeam').value;
            const away = document.getElementById('awayTeam').value;

            if (!home || !away || home === away) {
                alert('Please select two different teams!');
                return;
            }

            const homeData = teams[home];
            const awayData = teams[away];
            const homeAdvantage = 3;

            const homeStrength = homeData.rating + homeAdvantage + (Math.random() * 10 - 5);
            const awayStrength = awayData.rating + (Math.random() * 10 - 5);

            const total = homeStrength + awayStrength;
            const homeWinProb = Math.round((homeStrength / total) * 100);
            const awayWinProb = Math.round((awayStrength / total) * 100);
            const drawProb = Math.max(5, Math.round(30 - Math.abs(homeWinProb - awayWinProb) * 0.5));

            const adj = 100 - drawProb;
            const finalHome = Math.round(homeWinProb * adj / 100);
            const finalAway = Math.round(awayWinProb * adj / 100);

            const result = document.getElementById('predictionResult');
            const winner = document.getElementById('resultWinner');
            const bars = document.getElementById('resultBars');

            let winnerText = finalHome > finalAway ? `🏆 ${home} Favored` : `🏆 ${away} Favored`;
            if (Math.abs(finalHome - finalAway) < 5) winnerText = '⚖️ Too Close to Call';

            winner.textContent = winnerText;
            bars.innerHTML = `
                <div style="margin-bottom:12px;">
                    <div style="display:flex;justify-content:space-between;margin-bottom:4px;font-size:0.85rem;">
                        <span>${home} Win</span><span>${finalHome}%</span>
                    </div>
                    <div class="prediction-bar"><div class="prediction-fill" style="width:${finalHome}%"></div></div>
                </div>
                <div style="margin-bottom:12px;">
                    <div style="display:flex;justify-content:space-between;margin-bottom:4px;font-size:0.85rem;">
                        <span>Draw</span><span>${drawProb}%</span>
                    </div>
                    <div class="prediction-bar"><div class="prediction-fill" style="width:${drawProb}%;background:linear-gradient(90deg,#aaa,#888)"></div></div>
                </div>
                <div>
                    <div style="display:flex;justify-content:space-between;margin-bottom:4px;font-size:0.85rem;">
                        <span>${away} Win</span><span>${finalAway}%</span>
                    </div>
                    <div class="prediction-bar"><div class="prediction-fill" style="width:${finalAway}%;background:linear-gradient(90deg,#FF6B35,#FF4500)"></div></div>
                </div>
            `;

            result.classList.add('show');
        }

        // Render matches
        function renderMatches() {
            const grid = document.getElementById('matchesGrid');
            grid.innerHTML = sampleMatches.map(match => {
                const pred = getQuickPrediction(match.home, match.away);
                return `
                <div class="match-card">
                    <div class="match-header">
                        <span>Group ${match.group}</span>
                        <span class="match-badge">${match.date}</span>
                    </div>
                    <div class="teams-row">
                        <div class="team">
                            <span class="team-flag">${getFlag(match.home)}</span>
                            <div class="team-name">${match.home}</div>
                        </div>
                        <div class="vs-divider">VS</div>
                        <div class="team">
                            <span class="team-flag">${getFlag(match.away)}</span>
                            <div class="team-name">${match.away}</div>
                        </div>
                    </div>
                    <div class="prediction-bar">
                        <div class="prediction-fill" style="width:${pred.homeProb}%"></div>
                    </div>
                    <div class="prediction-labels">
                        <span>${match.home} ${pred.homeProb}%</span>
                        <span>${match.away} ${pred.awayProb}%</span>
                    </div>
                </div>
                `;
            }).join('');
        }

        function getQuickPrediction(home, away) {
            const h = teams[home].rating + 3;
            const a = teams[away].rating;
            const total = h + a;
            return {
                homeProb: Math.round((h / total) * 100),
                awayProb: Math.round((a / total) * 100)
            };
        }

        function getFlag(team) {
            const flags = {
                'Brazil': '🇧🇷', 'Argentina': '🇦🇷', 'France': '🇫🇷',
                'England': '🏴󠁧󠁢󠁥󠁮󠁧󠁿', 'Spain': '🇪🇸', 'Germany': '🇩🇪',
                'Portugal': '🇵🇹', 'Netherlands': '🇳🇱', 'USA': '🇺🇸',
                'Mexico': '🇲🇽', 'Canada': '🇨🇦', 'Morocco': '🇲🇦',
                'Japan': '🇯🇵', 'South Korea': '🇰🇷', 'Australia': '🇦🇺',
                'Senegal': '🇸🇳'
            };
            return flags[team] || '🏳️';
        }

        // Render groups
        function renderGroups() {
            const container = document.getElementById('groupsContainer');
            container.innerHTML = Object.entries(groups).map(([groupName, teamList]) => {
                const standings = teamList.map(team => ({
                    name: team,
                    played: Math.floor(Math.random() * 3),
                    points: Math.floor(Math.random() * 9),
                    gd: Math.floor(Math.random() * 6) - 2
                })).sort((a, b) => b.points - a.points);

                return `
                <div class="group-card">
                    <div class="group-title">Group ${groupName}</div>
                    <table class="standings-table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Team</th>
                                <th>P</th>
                                <th>Pts</th>
                                <th>GD</th>
                            </tr>
                        </thead>
                        <tbody>
                            ${standings.map((team, idx) => `
                            <tr>
                                <td><span class="rank-badge rank-${idx + 1}">${idx + 1}</span></td>
                                <td>${getFlag(team.name)} ${team.name}</td>
                                <td>${team.played}</td>
                                <td style="font-weight:700;color:${idx < 2 ? '#FFD700' : 'inherit'}">${team.points}</td>
                                <td>${team.gd > 0 ? '+' : ''}${team.gd}</td>
                            </tr>
                            `).join('')}
                        </tbody>
                    </table>
                </div>
                `;
            }).join('');
        }

        // Render stats
        function renderStats() {
            const grid = document.getElementById('statsGrid');
            const statsData = [
                { value: '48', label: 'Total Matches' },
                { value: '16', label: 'Group Matches' },
                { value: '32', label: 'Teams' },
                { value: '3', label: 'Host Nations' },
                { value: '16', label: 'Cities' },
                { value: '80K', label: 'Avg Attendance' }
            ];

            grid.innerHTML = statsData.map(s => `
                <div class="stat-card">
                    <div class="stat-value">${s.value}</div>
                    <div class="stat-label">${s.label}</div>
                </div>
            `).join('');
        }

        // Render bracket
        function renderBracket() {
            const container = document.getElementById('bracketContainer');
            const r16Teams = ['Brazil', 'Morocco', 'France', 'Japan', 'England', 'USA', 'Argentina', 'Germany'];
            container.innerHTML = `
                <div style="display:flex;gap:20px;min-width:600px;">
                    <div>
                        <div style="color:rgba(255,255,255,0.4);font-size:0.75rem;text-align:center;margin-bottom:10px;text-transform:uppercase;letter-spacing:1px;">Round of 16</div>
                        ${r16Teams.reduce((html, team, i) => {
                            if (i % 2 === 0) {
                                return html + `<div class="bracket-match">
                                    <div class="bracket-team ${i===0?'winner':''}">${getFlag(r16Teams[i])} ${r16Teams[i]}</div>
                                    <div class="bracket-team">${getFlag(r16Teams[i+1])} ${r16Teams[i+1]}</div>
                                </div>`;
                            }
                            return html;
                        }, '')}
                    </div>
                    <div>
                        <div style="color:rgba(255,255,255,0.4);font-size:0.75rem;text-align:center;margin-bottom:10px;text-transform:uppercase;letter-spacing:1px;">Quarter Finals</div>
                        <div class="bracket-match" style="margin-top:28px;">
                            <div class="bracket-team winner">${getFlag('Brazil')} Brazil</div>
                            <div class="bracket-team">${getFlag('France')} France</div>
                        </div>
                        <div class="bracket-match" style="margin-top:28px;">
                            <div class="bracket-team winner">${getFlag('England')} England</div>
                            <div class="bracket-team">${getFlag('Argentina')} Argentina</div>
                        </div>
                    </div>
                    <div>
                        <div style="color:rgba(255,255,255,0.4);font-size:0.75rem;text-align:center;margin-bottom:10px;text-transform:uppercase;letter-spacing:1px;">Semi Finals</div>
                        <div class="bracket-match" style="margin-top:80px;">
                            <div class="bracket-team winner">${getFlag('Brazil')} Brazil</div>
                            <div class="bracket-team">${getFlag('England')} England</div>
                        </div>
                    </div>
                    <div>
                        <div style="color:rgba(255,255,255,0.4);font-size:0.75rem;text-align:center;margin-bottom:10px;text-transform:uppercase;letter-spacing:1px;">🏆 Final</div>
                        <div class="bracket-match" style="margin-top:120px;border-color:rgba(255,215,0,0.3);">
                            <div class="bracket-team winner">${getFlag('Brazil')} Brazil</div>
                            <div class="bracket-team">${getFlag('France')} France</div>
                        </div>
                    </div>
                </div>
            `;
        }

        // Section navigation
        function showSection(name) {
            document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
            document.querySelectorAll('.nav-tab').forEach(t => t.classList.remove('active'));
            document.getElementById(name).classList.add('active');
            event.target.classList.add('active');
        }

        // Init
        renderMatches();
        renderGroups();
        renderStats();
        renderBracket();
    </script>
</body>
</html>
